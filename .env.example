# Required — MongoDB Atlas connection string (SRV format)
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_ENABLE_THINKING=true
JWT_SECRET=your-shared-jwt-secret-min-32-chars

# Optional
NODE_ENV=development
PORT=5000
CORS_ORIGINS=https://knowledge-vault.onrender.com,https://neural-query.onrender.com
